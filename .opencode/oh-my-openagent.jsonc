/**
 * AUDESYS 模型分层配置体系
 *
 * 五层模型映射: premium-max / premium / fast / vision / lite
 * 通过 New API 网关别名实现模型动态切换，项目配置零修改。
 * 详见: agent-model-tiers.md
 */
{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // Sisyphus
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": true,
    "replace_plan": false
  },

  // Team Mode
  "team_mode": {
    "enabled": true,
    "tmux_visualization": false,
    "max_parallel_members": 4
  },

  // ============================================================
  //  Agents: 五层模型体系
  //  premium-max: deepseek-v4-pro-max -> kimi-k2.6 -> minimax-m3
  //  premium:     deepseek-v4-pro     -> qwen3.7-max -> glm-5.1
  //  fast:        deepseek-v4-flash   -> qwen3.6-flash -> doubao-seed-2.0-lite
  //  vision:      doubao-seed-2.0-pro -> qwen3.6-plus -> gemini-3.5-flash
  //  lite:        qwen3-32b           -> qwen3-8b
  // ============================================================
  "agents": {
    // === premium-max: 极致推理 ===
    "oracle": {
      "model": "new-api/premium-max",
      "fallback_models": ["new-api/premium-max-1", "new-api/premium-max-2"],
      "reasoningEffort": "high",
      "temperature": 0.2
    },

    // === premium: 主力推理 ===
    "sisyphus": {
      "model": "new-api/premium",
      "fallback_models": ["new-api/premium-1", "new-api/premium-2"],
      "temperature": 0.2
    },

    "hephaestus": {
      "model": "new-api/premium",
      "fallback_models": ["new-api/premium-1", "new-api/premium-2"],
      "temperature": 0.2
    },

    "prometheus": {
      "model": "new-api/premium",
      "fallback_models": ["new-api/premium-1", "new-api/premium-2"],
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel.",
      "temperature": 0.2
    },

    "atlas": {
      "model": "new-api/premium",
      "fallback_models": ["new-api/premium-1", "new-api/premium-2"],
      "temperature": 0.2
    },

    // === fast: 极速执行 ===
    "librarian": {
      "model": "new-api/fast",
      "fallback_models": ["new-api/fast-1", "new-api/fast-2"],
      "temperature": 0.0
    },

    "explore": {
      "model": "new-api/fast",
      "fallback_models": ["new-api/fast-1", "new-api/fast-2"],
      "temperature": 0.0
    },

    "metis": {
      "model": "new-api/fast",
      "fallback_models": ["new-api/fast-1", "new-api/fast-2"],
      "temperature": 0.0
    },

    "momus": {
      "model": "new-api/fast",
      "fallback_models": ["new-api/fast-1", "new-api/fast-2"],
      "temperature": 0.0
    },

    "sisyphus-junior": {
      "model": "new-api/fast",
      "fallback_models": ["new-api/fast-1", "new-api/fast-2"],
      "temperature": 0.0
    },

    // === vision: 视觉专家 ===
    "multimodal-looker": {
      "model": "new-api/vision",
      "fallback_models": [
        "new-api/vision-1",
        "new-api/vision-2"
      ],
      "temperature": 0.1
    }
  },

  // ============================================================
  //  Categories: task() 分发
  // ============================================================
  "categories": {
    "visual-engineering": {
      "model": "new-api/premium",
      "fallback_models": ["new-api/premium-1", "new-api/premium-2"],
      "temperature": 0.4
    },

    "ultrabrain": {
      "model": "new-api/premium-max",
      "fallback_models": ["new-api/premium-max-1", "new-api/premium-max-2"],
      "reasoningEffort": "high",
      "temperature": 0.2
    },

    "deep": {
      "model": "new-api/premium",
      "fallback_models": ["new-api/premium-1", "new-api/premium-2"],
      "temperature": 0.2
    },

    "unspecified-high": {
      "model": "new-api/premium",
      "fallback_models": ["new-api/premium-1", "new-api/premium-2"],
      "reasoningEffort": "medium",
      "temperature": 0.1
    },

    "artistry": {
      "model": "new-api/fast",
      "fallback_models": ["new-api/fast-1", "new-api/fast-2"],
      "temperature": 0.6
    },

    "quick": {
      "model": "new-api/fast",
      "fallback_models": ["new-api/fast-1", "new-api/fast-2"],
      "temperature": 0.0,
      "maxTokens": 4096
    },

    "unspecified-low": {
      "model": "new-api/fast",
      "fallback_models": ["new-api/fast-1", "new-api/fast-2"],
      "temperature": 0.2
    },

    "writing": {
      "model": "new-api/fast",
      "fallback_models": ["new-api/fast-1", "new-api/fast-2"],
      "temperature": 0.3
    }
  },

  // Background Tasks
  "background_task": {
    "defaultConcurrency": 8,
    "staleTimeoutMs": 300000
  },

  // Runtime Fallback (disabled, using agent-level fallback_models)
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [402, 429, 500, 502, 503, 504],
    "max_fallback_attempts": 2,
    "cooldown_seconds": 60,
    "timeout_seconds":  60,
    "notify_on_fallback": true
  },

  // Experimental
  "experimental": {
    "aggressive_truncation": false,  // false+DCP: skip blind truncation, rely on ACP smart pruning; compaction.auto=false in opencode.json
    "task_system": true
  },

  // Hashline Edit
  "hashline_edit": true,

  // Disabled Hooks
  "disabled_hooks": ["no-sisyphus-gpt", "no-hephaestus-non-gpt"]
}
